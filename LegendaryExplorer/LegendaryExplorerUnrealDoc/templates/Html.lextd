		<meta property="og:type" content="website" />
		<title>%LD_TITLE%</title>
		<meta name="og:title" content="%LD_TITLE%"/>
		<meta name="description" content="%LD_DESCRIPTION%"/>
		<meta name="og:description" content="%LD_DESCRIPTION%"/>
		<meta name="og:url" content="https://me3tweaks.github.io/LegendaryExplorer/unrealdoc/%LD_GAME%/%LD_RELPATH%"/>
		<meta name="og:image" content="https://me3tweaks.github.io/idk.png"/>
		<link rel="stylesheet" href="%LD_RELPATH%lexdoc.css">
		<script type="text/javascript">
			document.addEventListener('DOMContentLoaded', function() {
				var url = window.location.href.substring(window.location.protocol.length + 2);
				var gameidx = url.indexOf("/%LD_GAME%/");
				var baseurl = url.substring(0, gameidx + 5);
				console.log(baseurl);
				var typelinks = document.querySelectorAll('[data-type]');
				for (const element of typelinks) {
					var type = element.dataset.type;
					var value = element.textContent;
					switch(type){
						case 'class':
							element.href = window.location.protocol + '//' + baseurl + 'classes/' + value + '.html';
							break;
						case 'struct':
							element.href = window.location.protocol + '//' + baseurl + 'structs/' + value + '.html';
							break;
						case 'enum':
							element.href = window.location.protocol + '//' + baseurl + 'enums/' + value + '.html';
							break;
					}
				}
			}, false);
		</script>
	</head>
